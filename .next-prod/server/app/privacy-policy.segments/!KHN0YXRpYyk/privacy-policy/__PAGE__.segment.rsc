4:["$","section",null,{"className":"privacy-policy-section","children":[["$","h2",null,{"children":"5. Data Security & HIPAA Context"}],["$","p",null,{"children":"While veterinary data is not technically governed by the human HIPAA framework in all jurisdictions, VetLink Clinical adopts HIPAA-compliant security protocols as our baseline standard. This includes:"}],["$","ul",null,{"className":"privacy-policy-list","children":[["$","li",null,{"children":"AES-256 encryption for data at rest and TLS 1.3 for data in transit."}],["$","li",null,{"children":"Role-based access controls (RBAC) and session management safeguards."}],["$","li",null,{"children":"Regular third-party security audits and penetration testing."}],["$","li",null,{"children":"Granular access monitoring for designated clinical teams."}]]}]]}]
5:["$","section",null,{"className":"privacy-policy-section","children":[["$","h2",null,{"children":"6. Your Rights"}],["$","p",null,{"children":"VETLIN Clinical provides professional users with the right to access, rectify, or request the deletion of personal account information. For clinical patient records, data retention follows state-mandated veterinary record keeping laws with typically required storage for a minimum of 3 to 7 years."}]]}]
