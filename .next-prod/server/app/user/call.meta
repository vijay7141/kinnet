{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/user/layout,_N_T_/user/call/layout,_N_T_/user/call/page,_N_T_/user/call"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/user/call/__PAGE__",
    "/user/call",
    "/user",
    "/_index",
    "/_head"
  ]
}